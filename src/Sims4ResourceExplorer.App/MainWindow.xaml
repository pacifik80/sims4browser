<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Sims4ResourceExplorer.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:Sims4ResourceExplorer.Core"
    xmlns:viewModels="using:Sims4ResourceExplorer.App.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Sims4 Resource Explorer"
    mc:Ignorable="d">
    <Grid Padding="12" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Click="Index_Click" Content="Update Index" IsEnabled="{Binding IsNotBusy}" />
            <Button Click="Refresh_Click" Content="Apply / Refresh" IsEnabled="{Binding IsNotBusy}" />
        </StackPanel>

        <Grid x:Name="MainContentGrid" Grid.Row="1" ColumnSpacing="0" SizeChanged="MainContentGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition x:Name="ResultsColumn" Width="4*" MinWidth="360" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition x:Name="PreviewColumn" Width="3*" MinWidth="460" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0">
                <StackPanel Spacing="12">
                    <TextBlock Text="Scope" FontSize="20" FontWeight="SemiBold" />

                    <ComboBox Header="Browser mode" ItemsSource="{Binding BrowserModes}" SelectedItem="{Binding SelectedBrowserMode, Mode=TwoWay}" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Source scope" FontWeight="SemiBold" />
                        <CheckBox Content="Game" IsChecked="{Binding IncludeGameSources, Mode=TwoWay}" />
                        <CheckBox Content="DLC" IsChecked="{Binding IncludeDlcSources, Mode=TwoWay}" />
                        <CheckBox Content="Mods" IsChecked="{Binding IncludeModsSources, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Configured folders" FontWeight="SemiBold" />
                        <TextBlock Text="Folders are managed from Update Index. Source kind is inferred from the path and can still be filtered below as Game, DLC, or Mods." Opacity="0.7" TextWrapping="WrapWholeWords" />
                        <ListView MaxHeight="220" ItemsSource="{Binding DataSources}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding RootPath}" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                    <StackPanel Visibility="{Binding AssetBrowserVisibility}" Spacing="8">
                        <TextBlock Text="Asset Browser facets" FontWeight="SemiBold" />
                        <ComboBox Header="Domain" ItemsSource="{Binding AssetDomains}" SelectedItem="{Binding AssetDomain, Mode=TwoWay}" />
                        <TextBlock Text="{Binding AssetFacetSummaryText}" Opacity="0.7" TextWrapping="WrapWholeWords" />

                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Identity" FontWeight="SemiBold" />
                                <AutoSuggestBox Header="Category" PlaceholderText="All" Text="{Binding AssetCategoryText, Mode=TwoWay}" ItemsSource="{Binding AssetCategories}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="Category" />
                                <AutoSuggestBox Header="Root type" PlaceholderText="All" Text="{Binding AssetRootTypeText, Mode=TwoWay}" ItemsSource="{Binding AssetRootTypes}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="RootType" />
                                <AutoSuggestBox Header="Identity type" PlaceholderText="All" Text="{Binding AssetIdentityTypeText, Mode=TwoWay}" ItemsSource="{Binding AssetIdentityTypes}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="IdentityType" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Structure" FontWeight="SemiBold" />
                                <AutoSuggestBox Header="Geometry type" PlaceholderText="All" Text="{Binding AssetPrimaryGeometryTypeText, Mode=TwoWay}" ItemsSource="{Binding AssetPrimaryGeometryTypes}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="GeometryType" />
                                <AutoSuggestBox Header="Thumbnail type" PlaceholderText="All" Text="{Binding AssetThumbnailTypeText, Mode=TwoWay}" ItemsSource="{Binding AssetThumbnailTypes}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="ThumbnailType" />
                                <TextBox Header="Package path contains" Text="{Binding AssetPackageText, Mode=TwoWay}" />
                                <TextBox Header="Package file / folder" PlaceholderText="EP01\\ClientFullBuild0.package" Text="{Binding AssetPackageRelativeText, Mode=TwoWay}" />
                                <CheckBox Content="Has thumbnail" IsChecked="{Binding AssetHasThumbnailOnly, Mode=TwoWay}" />
                                <CheckBox Content="Has variants" IsChecked="{Binding AssetVariantsOnly, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <Border Visibility="{Binding AssetCatalogSignalsVisibility}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Raw Catalog Signals" FontWeight="SemiBold" />
                                <TextBlock Text="Build/Buy only. These are raw ObjectCatalog values, not decoded gameplay categories." Opacity="0.7" TextWrapping="WrapWholeWords" />
                                <AutoSuggestBox Header="Catalog signal 0020" PlaceholderText="All" Text="{Binding AssetCatalogSignal0020Text, Mode=TwoWay}" ItemsSource="{Binding AssetCatalogSignal0020Values}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="CatalogSignal0020" />
                                <AutoSuggestBox Header="Catalog signal 002C" PlaceholderText="All" Text="{Binding AssetCatalogSignal002CText, Mode=TwoWay}" ItemsSource="{Binding AssetCatalogSignal002CValues}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="CatalogSignal002C" />
                                <AutoSuggestBox Header="Catalog signal 0030" PlaceholderText="All" Text="{Binding AssetCatalogSignal0030Text, Mode=TwoWay}" ItemsSource="{Binding AssetCatalogSignal0030Values}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="CatalogSignal0030" />
                                <AutoSuggestBox Header="Catalog signal 0034" PlaceholderText="All" Text="{Binding AssetCatalogSignal0034Text, Mode=TwoWay}" ItemsSource="{Binding AssetCatalogSignal0034Values}" TextChanged="AssetFacetSuggestBox_TextChanged" SuggestionChosen="AssetFacetSuggestBox_SuggestionChosen" GotFocus="AssetFacetSuggestBox_GotFocus" Tag="CatalogSignal0034" />
                            </StackPanel>
                        </Border>

                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Capabilities" FontWeight="SemiBold" />
                                <CheckBox Content="Has scene root" IsChecked="{Binding AssetRequireSceneRoot, Mode=TwoWay}" />
                                <CheckBox Content="Has identity metadata" IsChecked="{Binding AssetRequireIdentityMetadata, Mode=TwoWay}" />
                                <CheckBox Content="Has exact geometry candidate" IsChecked="{Binding AssetRequireExactGeometryCandidate, Mode=TwoWay}" />
                                <CheckBox Content="Has geometry reference" IsChecked="{Binding AssetRequireGeometryReference, Mode=TwoWay}" />
                                <CheckBox Content="Has rig reference" IsChecked="{Binding AssetRequireRigReference, Mode=TwoWay}" />
                                <CheckBox Content="Has material refs" IsChecked="{Binding AssetRequireMaterialReferences, Mode=TwoWay}" />
                                <CheckBox Content="Has texture refs" IsChecked="{Binding AssetRequireTextureReferences, Mode=TwoWay}" />
                                <CheckBox Content="Has material candidate" IsChecked="{Binding AssetRequireMaterialResourceCandidate, Mode=TwoWay}" />
                                <CheckBox Content="Has texture candidate" IsChecked="{Binding AssetRequireTextureResourceCandidate, Mode=TwoWay}" />
                                <CheckBox Content="Package-local graph" IsChecked="{Binding AssetRequirePackageLocalGraph, Mode=TwoWay}" />
                                <CheckBox Content="Has diagnostics" IsChecked="{Binding AssetRequireDiagnostics, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>

                        <ComboBox Header="Sort" ItemsSource="{Binding AssetSortOptions}" SelectedItem="{Binding AssetSort, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Visibility="{Binding RawBrowserVisibility}" Spacing="8">
                        <TextBlock Text="Raw Resource facets" FontWeight="SemiBold" />
                        <ComboBox Header="Domain" ItemsSource="{Binding RawDomains}" SelectedItem="{Binding RawDomain, Mode=TwoWay}" />
                        <TextBox Header="Type name contains" Text="{Binding RawTypeNameText, Mode=TwoWay}" />
                        <TextBox Header="Package path contains" Text="{Binding RawPackageText, Mode=TwoWay}" />
                        <TextBox Header="Group hex contains" Text="{Binding RawGroupHexText, Mode=TwoWay}" />
                        <TextBox Header="Instance hex contains" Text="{Binding RawInstanceHexText, Mode=TwoWay}" />
                        <CheckBox Content="Previewable only" IsChecked="{Binding RawPreviewableOnly, Mode=TwoWay}" />
                        <CheckBox Content="Export-capable only" IsChecked="{Binding RawExportCapableOnly, Mode=TwoWay}" />
                        <CheckBox Content="Compression known" IsChecked="{Binding RawCompressedKnownOnly, Mode=TwoWay}" />
                        <ComboBox Header="Link filter" ItemsSource="{Binding LinkFilters}" SelectedItem="{Binding RawLinkFilter, Mode=TwoWay}" />
                        <ComboBox Header="Sort" ItemsSource="{Binding RawSortOptions}" SelectedItem="{Binding RawSort, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="1" Margin="12,0,12,0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Visibility="{Binding AssetBrowserVisibility}" Spacing="4">
                    <TextBox Header="Asset Browser search" PlaceholderText="{Binding AssetSearchPlaceholder}" Text="{Binding AssetSearchText, Mode=TwoWay}" />
                    <TextBlock Text="{Binding AssetSearchHelp}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel Visibility="{Binding RawBrowserVisibility}" Spacing="4">
                    <TextBox Header="Raw Resource Browser search" PlaceholderText="{Binding RawSearchPlaceholder}" Text="{Binding RawSearchText, Mode=TwoWay}" />
                    <TextBlock Text="{Binding RawSearchHelp}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="6">
                    <TextBlock Text="{Binding ResultSummary}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                    <ScrollViewer HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Hidden">
                        <ItemsControl ItemsSource="{Binding ActiveFilterChips}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="6" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Click="RemoveFilterChip_Click" Content="{Binding Label}" Tag="{Binding Key}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                    <Button Click="Refresh_Click" Content="Apply Filters" IsEnabled="{Binding IsNotBusy}" />
                    <Button Click="ResetFilters_Click" Content="Reset Filters" IsEnabled="{Binding IsNotBusy}" />
                </StackPanel>

                <Grid Grid.Row="3">
                    <ListView x:Name="AssetsListView" ItemsSource="{Binding AssetResults}" SelectionChanged="AssetsListView_SelectionChanged" Visibility="{Binding AssetBrowserVisibility}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding SupportLabel}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding KindLabel}" />
                                    <TextBlock Grid.Column="2" Text="{Binding PrimaryGeometryType}" />
                                    <TextBlock Grid.Column="3" Text="{Binding VariantCount}" />
                                    <TextBlock Grid.Column="4" Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ListView x:Name="ResourcesListView" ItemsSource="{Binding RawResources}" SelectionChanged="ResourcesListView_SelectionChanged" Visibility="{Binding RawBrowserVisibility}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Key.TypeName}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Key.FullTgi}" FontFamily="Consolas" />
                                    <TextBlock Grid.Column="2" Text="{Binding PreviewKind}" />
                                    <TextBlock Grid.Column="3" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="18,12" Visibility="{Binding EmptyStateVisibility}">
                        <TextBlock Text="{Binding EmptyStateMessage}" TextWrapping="WrapWholeWords" />
                    </Border>
                </Grid>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="8">
                    <Button Click="LoadMore_Click" Content="Load More" IsEnabled="{Binding HasMoreResults}" />
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Grid>

            <Border Grid.Column="2"
                    Background="{ThemeResource AccentFillColorSecondaryBrush}"
                    Opacity="0.35"
                    PointerPressed="MainPaneSplitter_PointerPressed"
                    PointerMoved="MainPaneSplitter_PointerMoved"
                    PointerReleased="MainPaneSplitter_PointerReleased"
                    PointerCanceled="MainPaneSplitter_PointerReleased" />

            <Grid x:Name="PreviewPaneGrid" Grid.Column="3" Margin="12,0,0,0" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="PreviewViewportRow" Height="*" MinHeight="180" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition x:Name="PreviewDiagnosticsRow" Height="*" MinHeight="120" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding PreviewSurfaceTitle}" FontSize="16" FontWeight="SemiBold" />
                <Grid x:Name="PreviewSurface" Grid.Row="1">
                    <Image x:Name="UvPreviewImage" Stretch="Uniform" Visibility="Collapsed" />
                    <Image x:Name="PreviewImage" Stretch="Uniform" Source="{Binding PreviewImageSource}" />
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="8" Visibility="{Binding DiagnosticsPreviewVisibility}">
                        <TextBox Text="{Binding PreviewText}" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" />
                    </Border>
                </Grid>
                <StackPanel Grid.Row="2" Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding EffectivePreviewLoadStatus}" Opacity="0.8" TextWrapping="NoWrap" VerticalAlignment="Center" />
                        <ProgressBar Grid.Column="1"
                                     Maximum="{Binding PreviewLoadProgressMaximum}"
                                     Value="{Binding PreviewLoadProgressValue}"
                                     IsIndeterminate="{Binding PreviewLoadProgressIndeterminate}"
                                     Foreground="{Binding PreviewLoadBrush}"
                                     VerticalAlignment="Center" />
                    </Grid>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Click="CopyPreviewImage_Click" ToolTipService.ToolTip="Copy preview image" MinWidth="32" Padding="8,4">
                            <SymbolIcon Symbol="Copy" />
                        </Button>
                        <Button Click="ExportRaw_Click" Content="Raw Export" />
                        <Button Click="ExportAsset_Click" Content="Export Asset" IsEnabled="{Binding CanExportSelectedAsset}" />
                        <Button x:Name="ResetViewButton" Click="ResetView_Click" Content="Reset View" IsEnabled="{Binding CanResetView}" />
                        <Button Click="PlayAudio_Click" Content="Play" />
                        <Button Click="StopAudio_Click" Content="Stop" />
                    </StackPanel>
                    <Border Visibility="{Binding AssetVariantPickerVisibility}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Variants" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding AssetVariantPickerSummary}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                            <ComboBox Header="Variant"
                                      ItemsSource="{Binding AssetVariantItems}"
                                      SelectedItem="{Binding SelectedAssetVariant, Mode=TwoWay}"
                                      IsEnabled="{Binding CanSelectAssetVariant}" />
                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    CornerRadius="6"
                                    Padding="10">
                                <Grid ColumnSpacing="12" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding SelectedAssetVariantDescriptor}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{Binding SelectedAssetVariantMetadataText}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <Image Grid.Column="1"
                                           Width="72"
                                           Height="72"
                                           Stretch="Uniform"
                                           Source="{Binding SelectedAssetVariantThumbnailSource}"
                                           Visibility="{Binding SelectedAssetVariantThumbnailVisibility}" />
                                    <TextBlock Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding SelectedAssetVariantThumbnailText}"
                                               Opacity="0.7"
                                               TextWrapping="WrapWholeWords" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Visibility="{Binding SimArchetypeInspectorVisibility}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Sim Archetype" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SimArchetypeInspectorSummary}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                            <TabView SelectedIndex="{Binding SelectedSimArchetypeTabIndex, Mode=TwoWay}"
                                     IsAddTabButtonVisible="False"
                                     CanReorderTabs="False">
                                <TabViewItem Header="Body" IsClosable="False">
                                    <ScrollViewer MaxHeight="240"
                                                  VerticalScrollMode="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="10" Padding="0,4,0,0">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Template Variations" FontWeight="SemiBold" />
                                                <TextBlock Text="Archetypes group multiple SimInfo templates. Pick one template to inspect its body inputs and drive the current base-body preview."
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords" />
                                                <ComboBox ItemsSource="{Binding SelectedSimTemplateOptions}"
                                                          SelectedItem="{Binding SelectedSimTemplateOption, Mode=TwoWay}"
                                                          DisplayMemberPath="DisplayLabel"
                                                          PlaceholderText="No grouped SimInfo templates resolved yet" />
                                                <TextBlock Text="{Binding SelectedSimTemplateNotesText}"
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords"
                                                           MaxLines="3"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding SelectedSimTemplateDetailsText}"
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords"
                                                           MaxLines="2"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Body Foundation" FontWeight="SemiBold" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimBodyFoundation}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="core:SimBodyFoundationSummary">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind Count}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind Notes}" Opacity="0.7" TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Current Slot References" FontWeight="SemiBold" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimSlotGroups}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="core:SimSlotGroupSummary">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind Count}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind Notes}" Opacity="0.7" TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Body Source References" FontWeight="SemiBold" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimBodySources}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="core:SimBodySourceSummary">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind Count}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind Notes}" Opacity="0.7" TextWrapping="WrapWholeWords" MaxLines="3" TextTrimming="CharacterEllipsis" FontFamily="Consolas" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Resolved Body Candidate Assets" FontWeight="SemiBold" />
                                                <TextBlock Text="These body-assembly families drive the current base-body preview. Authoritative SimInfo outfit/body-part selections are inspected first, but only a real body foundation should drive preview; if that is still missing, the app falls back to compatible default body candidates inferred from the template and catalog facts."
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimBodyCandidateFamilies}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="viewModels:SimBodyCandidateFamilyPickerItem">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind Count}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind Notes}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords"
                                                                               MaxLines="2"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <ComboBox ItemsSource="{x:Bind Options}"
                                                                              SelectedItem="{x:Bind SelectedOption, Mode=TwoWay}"
                                                                              DisplayMemberPath="DisplayLabel"
                                                                              PlaceholderText="No resolved body asset is available yet"
                                                                              IsEnabled="{x:Bind HasOptions}" />
                                                                    <TextBlock Text="{x:Bind SelectedOptionLabel}"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="NoWrap"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{x:Bind SelectionDetailsText}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords"
                                                                               MaxLines="3"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Current Body Assembly Recipe" FontWeight="SemiBold" />
                                                <TextBlock Text="This is the current base-body recipe that feeds the preview. Active layers participate in the current body foundation path; overridden layers stay available for inspection but are not used in the current rendered body scene."
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding SimBodyAssemblyModeText}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="WrapWholeWords" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimBodyAssemblyRecipe}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="viewModels:SimBodyAssemblyRecipeItem">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind ActivityLabel}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind Contribution}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords" />
                                                                    <TextBlock Text="{x:Bind SelectedAssetLabel}"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="NoWrap"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{x:Bind SourceLabel}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords" />
                                                                    <TextBlock Text="{x:Bind Notes}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords"
                                                                               MaxLines="3"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Resolved Base-Body Graph" FontWeight="SemiBold" />
                                                <TextBlock Text="This is the current runtime layer graph derived from the selected body families: which layers act as shell, which remain overlays, and which are only alternates right now."
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding SimResolvedBodyGraphSummaryText}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="WrapWholeWords" />
                                                <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        CornerRadius="6"
                                                        Padding="8">
                                                    <TextBlock Text="{Binding SimResolvedBodyGraphDetailsText}"
                                                               FontFamily="Consolas"
                                                               TextWrapping="WrapWholeWords"
                                                               MaxLines="10"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Body Graph" FontWeight="SemiBold" />
                                                <TextBlock Text="These are the current base-body assembly stages for the selected template: what is already resolved, what is still approximate, and what remains pending."
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding SimBodyGraphSummaryText}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="WrapWholeWords" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimBodyGraphNodes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="core:SimBodyGraphNodeSummary">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind State}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind Notes}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords"
                                                                               MaxLines="3"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Proxy Preview Coverage" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding SimBodyPreviewCoverageText}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="WrapWholeWords" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimBodyPreviewCoverage}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="viewModels:SimBodyPreviewCoverageItem">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind StatusLabel}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind Notes}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords"
                                                                               MaxLines="3"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Active Preview Layers" FontWeight="SemiBold" />
                                                <TextBlock Text="These are the actual body-related CAS assets that made it into the current base-body preview after family selection and GEOM validation."
                                                           Opacity="0.7"
                                                           TextWrapping="WrapWholeWords" />
                                                <ItemsControl ItemsSource="{Binding SelectedSimBodyPreviewLayers}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="viewModels:SimBodyPreviewLayerItem">
                                                            <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                    CornerRadius="6"
                                                                    Padding="8"
                                                                    Margin="0,0,0,6">
                                                                <StackPanel Spacing="4">
                                                                    <Grid ColumnSpacing="8">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*" />
                                                                            <ColumnDefinition Width="Auto" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                        <TextBlock Grid.Column="1" Text="{x:Bind StatusLabel}" Opacity="0.85" />
                                                                    </Grid>
                                                                    <TextBlock Text="{x:Bind AssetLabel}"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="NoWrap"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{x:Bind Notes}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords" />
                                                                    <TextBlock Text="{x:Bind PackageLabel}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords" />
                                                                    <TextBlock Text="{x:Bind RootTgi}"
                                                                               Opacity="0.7"
                                                                               TextWrapping="WrapWholeWords"
                                                                               FontFamily="Consolas"
                                                                               MaxLines="2"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabViewItem>
                                <TabViewItem Header="Morphs" IsClosable="False">
                                    <ScrollViewer MaxHeight="240"
                                                  VerticalScrollMode="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="6" Padding="0,4,0,0">
                                            <TextBlock Text="Morph Groups" FontWeight="SemiBold" />
                                            <ItemsControl ItemsSource="{Binding SelectedSimMorphGroups}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="core:SimMorphGroupSummary">
                                                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                CornerRadius="6"
                                                                Padding="8"
                                                                Margin="0,0,0,6">
                                                            <StackPanel Spacing="4">
                                                                <Grid ColumnSpacing="8">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                    <TextBlock Grid.Column="1" Text="{x:Bind Count}" Opacity="0.85" />
                                                                </Grid>
                                                                <TextBlock Text="{x:Bind Notes}" Opacity="0.7" TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabViewItem>
                                <TabViewItem Header="CAS" IsClosable="False">
                                    <ScrollViewer MaxHeight="240"
                                                  VerticalScrollMode="Auto"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel Spacing="6" Padding="0,4,0,0">
                                            <TextBlock Text="Clothing and accessory slots stay secondary for now; body assembly should start from the Body tab foundations and morph stack. Authoritative SimInfo outfit/body-part selections win first here too, with compatibility search only filling the gaps." Opacity="0.7" TextWrapping="WrapWholeWords" />
                                            <TextBlock Text="CAS Slot Candidates" FontWeight="SemiBold" />
                                            <ItemsControl ItemsSource="{Binding SelectedSimCasSlotFamilies}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="viewModels:SimCasSlotFamilyPickerItem">
                                                        <Border Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                                CornerRadius="6"
                                                                Padding="8"
                                                                Margin="0,0,0,6">
                                                            <StackPanel Spacing="4">
                                                                <Grid ColumnSpacing="8">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{x:Bind Label}" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                                    <TextBlock Grid.Column="1" Text="{x:Bind Count}" Opacity="0.85" />
                                                                </Grid>
                                                                <TextBlock Text="{x:Bind Notes}" Opacity="0.7" TextWrapping="WrapWholeWords" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{x:Bind SourceLabel}" Opacity="0.7" TextWrapping="WrapWholeWords" />
                                                                <ComboBox ItemsSource="{x:Bind Options}"
                                                                          SelectedItem="{x:Bind SelectedOption, Mode=TwoWay}"
                                                                          DisplayMemberPath="DisplayLabel"
                                                                          PlaceholderText="No indexed candidates yet"
                                                                          IsEnabled="{x:Bind HasOptions}" />
                                                                <TextBlock Text="{x:Bind SelectedOptionLabel}"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="NoWrap"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{x:Bind SelectionDetailsText}"
                                                                           Opacity="0.7"
                                                                           TextWrapping="WrapWholeWords"
                                                                           FontFamily="Consolas"
                                                                           MaxLines="2"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </ScrollViewer>
                                </TabViewItem>
                            </TabView>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox Width="160" Header="Render" ItemsSource="{Binding SceneRenderModes}" SelectedItem="{Binding SelectedSceneRenderMode, Mode=TwoWay}" />
                        <ComboBox Width="180" Header="Slot" ItemsSource="{Binding AvailableSceneTextureSlots}" SelectedItem="{Binding SelectedSceneTextureSlot, Mode=TwoWay}" IsEnabled="{Binding HasSceneTextureSlotOptions}" />
                        <ComboBox Width="320" Header="LOD" ItemsSource="{Binding AvailableSceneLods}" SelectedItem="{Binding SelectedSceneLod, Mode=TwoWay}" DisplayMemberPath="Label" IsEnabled="{Binding HasSceneLodOptions}" />
                    </StackPanel>
                </StackPanel>
                <Grid Grid.Row="3"
                      Canvas.ZIndex="10"
                      Background="Transparent"
                      MinHeight="12"
                      PointerPressed="PreviewPaneSplitter_PointerPressed"
                      PointerMoved="PreviewPaneSplitter_PointerMoved"
                      PointerReleased="PreviewPaneSplitter_PointerReleased"
                      PointerCanceled="PreviewPaneSplitter_PointerReleased">
                    <Border Height="4"
                            VerticalAlignment="Center"
                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                            Opacity="0.35"
                            IsHitTestVisible="False" />
                </Grid>
                <Grid Grid.Row="4" Visibility="{Binding DiagnosticsTabsVisibility}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="8" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Diagnostics" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="CopyDiagnostics_Click" ToolTipService.ToolTip="Copy current tab" MinWidth="32" Padding="8,4">
                            <SymbolIcon Symbol="Copy" />
                        </Button>
                    </Grid>
                    <TabView Grid.Row="1" SelectedIndex="{Binding SelectedPreviewDiagnosticsTabIndex, Mode=TwoWay}" IsAddTabButtonVisible="False" CanReorderTabs="False">
                        <TabViewItem Header="Preview" IsClosable="False">
                            <TextBox Text="{Binding PreviewText}" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" />
                        </TabViewItem>
                        <TabViewItem Header="Details" IsClosable="False">
                            <TextBox Text="{Binding DetailsText}" AcceptsReturn="True" IsReadOnly="True" TextWrapping="Wrap" />
                        </TabViewItem>
                    </TabView>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Padding="10,6,10,0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="WrapWholeWords" />
        </Border>
    </Grid>
</Window>
